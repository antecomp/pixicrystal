{
  "name": "BNY",
  "scopeName": "source.bny",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#variable"
    },
    {
      "include": "#block-tag"
    },
    {
      "include": "#match-tag"
    },
    {
      "include": "#match-branch"
    },
    {
      "include": "#label"
    },
    {
      "include": "#goto"
    },
    {
      "include": "#option"
    },
    {
      "include": "#directive"
    },
    {
      "include": "#brace"
    }
  ],
  "repository": {
    "variable": {
      "patterns": [
        {
          "name": "variable.other.bny",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.bny",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "label": {
      "patterns": [
        {
          "name": "meta.label.bny",
          "match": "^(\\s*)(@)(\\s*)([^#{}\\n].*?)\\s*$",
          "captures": {
            "2": {
              "name": "keyword.control.label.bny"
            },
            "4": {
              "name": "entity.name.label.bny"
            }
          }
        }
      ]
    },
    "block-tag": {
      "patterns": [
        {
          "name": "meta.block.skip.begin.bny",
          "match": "^(\\s*)(\\[)(block)(:)([^\\]\\n]+)(\\])\\s*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.tag.begin.bny"
            },
            "3": {
              "name": "keyword.control.block.bny"
            },
            "4": {
              "name": "punctuation.separator.key-value.bny"
            },
            "5": {
              "name": "entity.name.label.bny"
            },
            "6": {
              "name": "punctuation.definition.tag.end.bny"
            }
          }
        },
        {
          "name": "meta.block.skip.end.bny",
          "match": "^(\\s*)(\\[\\/)(block)(\\])\\s*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.tag.begin.bny"
            },
            "3": {
              "name": "keyword.control.block.bny"
            },
            "4": {
              "name": "punctuation.definition.tag.end.bny"
            }
          }
        }
      ]
    },
    "match-tag": {
      "patterns": [
        {
          "name": "meta.match.begin.bny",
          "match": "^(\\s*)(\\[)(match)(:)([^\\]\\n]+)(\\])\\s*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.tag.begin.bny"
            },
            "3": {
              "name": "keyword.control.match.bny"
            },
            "4": {
              "name": "punctuation.separator.key-value.bny"
            },
            "5": {
              "name": "entity.name.function.match.bny"
            },
            "6": {
              "name": "punctuation.definition.tag.end.bny"
            }
          }
        },
        {
          "name": "meta.match.end.bny",
          "match": "^(\\s*)(\\[\\/)(match)(\\])\\s*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.tag.begin.bny"
            },
            "3": {
              "name": "keyword.control.match.bny"
            },
            "4": {
              "name": "punctuation.definition.tag.end.bny"
            }
          }
        }
      ]
    },
    "match-branch": {
      "patterns": [
        {
          "name": "meta.match.branch.bny",
          "match": "^(\\s*)(=)(\\s*)([^#{}\\[\\]\\n].*?)\\s*$",
          "captures": {
            "2": {
              "name": "keyword.control.match-case.bny"
            },
            "4": {
              "name": "constant.other.match-case.bny"
            }
          }
        }
      ]
    },
    "goto": {
      "patterns": [
        {
          "name": "meta.goto.bny",
          "match": "^(\\s*)(->)(\\s*)([^#{}\\n].*?)\\s*$",
          "captures": {
            "2": {
              "name": "keyword.control.goto.bny"
            },
            "4": {
              "name": "entity.name.label.bny"
            }
          }
        }
      ]
    },
    "option": {
      "patterns": [
        {
          "name": "meta.option.bny",
          "match": "^(\\s*)(\\?:)(\\s*)(.*?)(\\s*)(\\{)?\\s*$",
          "captures": {
            "2": {
              "name": "keyword.control.option.bny"
            },
            "4": {
              "name": "string.unquoted.option-text.bny"
            },
            "6": {
              "name": "punctuation.section.block.begin.bny"
            }
          }
        }
      ]
    },
    "directive": {
      "patterns": [
        {
          "name": "meta.directive.bny",
          "match": "<([A-Za-z_][\\w-]*)(:)([^>]+)>",
          "captures": {
            "1": {
              "name": "entity.name.function.directive.bny"
            },
            "2": {
              "name": "punctuation.separator.key-value.bny"
            },
            "3": {
              "name": "string.unquoted.directive-value.bny"
            }
          }
        }
      ]
    },
    "brace": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.bny",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.bny",
          "match": "\\}"
        }
      ]
    }
  }
}
